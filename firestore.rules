rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPERS ──
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuth() && (
        request.auth.token.admin == true ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isSafeProfileUpdate() {
      let allowed = ['displayName','phoneNumber','networkProvider',
                     'profileComplete','themePreference','soundEnabled',
                     'notificationPrefs'];
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }

    // ── USERS ──
    match /users/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) && isAuth();
      allow update: if (isOwner(uid) && isSafeProfileUpdate()) || isAdmin();
      allow delete: if false;
    }

    // ── USER STATS ──
    match /userStats/{uid} {
      allow read:  if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid) || isAdmin();
    }

    // ── USER ACHIEVEMENTS ──
    match /userAchievements/{uid} {
      allow read:  if isOwner(uid) || isAdmin();
      allow write: if isAdmin();
    }

    // ── USER DAILY STATE ──
    match /userDailyState/{uid} {
      allow read:  if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid) || isAdmin();
    }

    // ── QUIZ SESSIONS ──
    match /quizSessions/{sessionId} {
      allow read:   if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── QUIZ ATTEMPTS ──
    match /quizAttempts/{attemptId} {
      allow read:   if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── LEADERBOARD ──
    match /leaderboardWeekly/{weekId} {
      allow read: if true;
      allow write: if isAdmin();

      match /entries/{uid} {
        allow read:   if true;
        allow write:  if isAuth() || isAdmin();
        allow delete: if isAdmin();
      }
    }

    // ── WEEKLY WINNERS ──
    match /weeklyWinners/{weekId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── REWARD CLAIMS ──
    match /rewardClaims/{claimId} {
      allow read:   if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── QUESTIONS ──
    match /questions/{questionId} {
      allow read:  if true;
      allow write: if isAdmin();

      match /analytics/{doc} {
        allow read:  if isAdmin();
        allow write: if isAuth();
      }
    }

    // ── NOTIFICATIONS ──
    match /notifications/{notificationId} {
      allow read:   if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAuth() && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow create: if isAdmin();
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── PUSH TOKENS ──
    match /userPushTokens/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    // ── ANNOUNCEMENTS ──
    match /announcements/{announcementId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── ADMIN LOGS ──
    match /adminLogs/{logId} {
      allow read, write: if isAdmin();
      allow create: if isAuth();
    }

    // ── MATCHES (challenge system) ──
    // SINGLE BLOCK — any authenticated user can read/query matches
    // This is required for the "accept by code" flow to work
    match /matches/{matchId} {
      // READ: any authenticated user can read matches (needed for code lookup queries)
      // Admin can read all. App logic enforces expiration and status checks.
      allow read: if isAuth() || isAdmin();

      // CREATE: authenticated user creating their own challenge
      allow create: if isAuth() && request.resource.data.creatorId == request.auth.uid;

      // UPDATE: creator, opponent, or admin can update
      // Also allows any auth user to join a WAITING match (become opponent)
      allow update: if isAdmin() || (
        isAuth() && (
          resource.data.creatorId == request.auth.uid ||
          resource.data.opponentId == request.auth.uid ||
          resource.data.status == 'waiting'
        )
      );

      allow delete: if isAdmin();
    }

    // ── DEFAULT DENY ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
