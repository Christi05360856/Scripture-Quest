rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPERS ──
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Check admin via custom claim OR Firestore role document
    function isAdmin() {
      return isAuth() && (
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isSafeProfileUpdate() {
      let allowed = ['displayName','phoneNumber','networkProvider',
                     'profileComplete','themePreference','soundEnabled',
                     'notificationPrefs'];
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }

    // ── USERS ──
    match /users/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) && isAuth();
      allow update: if (isOwner(uid) && isSafeProfileUpdate()) || isAdmin();
      allow delete: if false;
    }

    // ── USER STATS ──
    match /userStats/{uid} {
      allow read:  if isOwner(uid) || isAdmin();
      allow write: if isAdmin();
    }

    // ── USER ACHIEVEMENTS ──
    match /userAchievements/{uid} {
      allow read:  if isOwner(uid) || isAdmin();
      allow write: if isAdmin();
    }

    // ── USER DAILY STATE ──
    match /userDailyState/{uid} {
      allow read:  if isOwner(uid) || isAdmin();
      allow write: if isAdmin();
    }

    // ── QUIZ SESSIONS ──
    match /quizSessions/{sessionId} {
      allow read:   if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── QUIZ ATTEMPTS ──
    match /quizAttempts/{attemptId} {
      allow read:   if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth(); // Allow client writes for local quiz fallback
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── LEADERBOARD ──
    match /leaderboardWeekly/{weekId} {
      allow read: if true;
      allow write: if isAdmin();

      match /entries/{uid} {
        allow read:   if true;
        allow write:  if isAuth() || isAdmin(); // Allow client for local quiz
        allow delete: if isAdmin();
      }
    }

    // ── WEEKLY WINNERS ──
    match /weeklyWinners/{weekId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── REWARD CLAIMS ──
    match /rewardClaims/{claimId} {
      allow read:   if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── QUESTIONS ──
    match /questions/{questionId} {
      allow read:  if true;
      allow write: if isAdmin();

      match /analytics/{doc} {
        allow read:  if isAdmin();
        allow write: if isAuth(); // Written by local quiz service
      }
    }

    // ── NOTIFICATIONS ──
    match /notifications/{notificationId} {
      allow read:   if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAuth() && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow create: if isAdmin();
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── PUSH TOKENS ──
    match /userPushTokens/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    // ── ANNOUNCEMENTS ──
    match /announcements/{announcementId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── ADMIN LOGS ──
    match /adminLogs/{logId} {
      allow read, write: if isAdmin();
      allow create: if isAuth(); // System logs from client
    }

    // ── USER STATS (allow client writes for local quiz fallback) ──
    // Override above to let localquiz.service.js write stats
    match /userStats/{uid} {
      allow read:  if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid) || isAdmin();
    }

    match /userDailyState/{uid} {
      allow read:  if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid) || isAdmin();
    }

    // ── MATCHES (challenge system) ──
    match /matches/{matchId} {
      // Anyone can read a match they're part of OR if they have the code (waiting status)
      allow read: if isAuth() && (
        resource.data.creatorId  == request.auth.uid ||
        resource.data.opponentId == request.auth.uid ||
        resource.data.status     == 'waiting'
      );

      // Create: authenticated users can create challenges
      allow create: if isAuth() && request.resource.data.creatorId == request.auth.uid;

      // Update: creator or opponent can update (submit answers)
      allow update: if isAuth() && (
        resource.data.creatorId  == request.auth.uid ||
        resource.data.opponentId == request.auth.uid ||
        isAdmin()
      );

      allow delete: if isAdmin();
    }

    // ── MATCHES (Head-to-Head challenges) ──
    match /matches/{matchId} {
      allow read:   if isAuth() && (
        resource.data.creatorId == request.auth.uid ||
        resource.data.opponentId == request.auth.uid ||
        resource.data.status == 'waiting'
      );
      allow create: if isAuth() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.creatorId  == request.auth.uid ||
        resource.data.opponentId == request.auth.uid ||
        (resource.data.status == 'waiting' && resource.data.creatorId != request.auth.uid)
      );
      allow delete: if false;
      allow read, write: if isAdmin();
    }

    // ── DEFAULT DENY ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
